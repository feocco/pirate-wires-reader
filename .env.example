SERVICE_PORT=8123
HOST_BIND_ADDR=127.0.0.1
PIRATE_RADIO_PUBLIC_URL=https://pirate-radio.example.ts.net
PIRATE_RADIO_LIBRARY_DIR=/data/library
PIRATE_RADIO_STATE_PATH=/data/state.json
PIRATE_RADIO_FEED_URL=https://piratewires.substack.com/feed.xml
PIRATE_RADIO_POLL_INTERVAL_MS=900000
PIRATE_RADIO_MAX_NOTIFICATIONS_PER_POLL=1
PWR_HEADLESS=true
HOMELAB_FUNCTIONS_URL=http://host.docker.internal:8091
HOMELAB_FUNCTIONS_TOKEN=replace-with-runtime-secret
HA_URL=http://homeassistant.local:8123
HA_LONG_LIVED_TOKEN=replace-with-runtime-secret
OPENAI_API_KEY=replace-with-runtime-secret
